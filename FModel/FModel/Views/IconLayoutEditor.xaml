<adonisControls:AdonisWindow x:Class="FModel.Views.IconLayoutEditor"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:converters="clr-namespace:FModel.Views.Resources.Converters"
         xmlns:controls="clr-namespace:FModel.Views.Resources.Controls"
         xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
         xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
         xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
         xmlns:settings="clr-namespace:FModel.Settings"
         Title="アイコンレイアウト編集" WindowStartupLocation="CenterScreen" IconVisibility="Collapsed"
         Width="1180" Height="760" MinWidth="900" MinHeight="600">
    <adonisControls:AdonisWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Resources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <LinearGradientBrush x:Key="FModelJP5WindowBackgroundDark" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#111827" Offset="0" />
                <GradientStop Color="#1F2937" Offset="0.5" />
                <GradientStop Color="#0B1220" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="FModelJP5WindowBackgroundLight" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F4F7FB" Offset="0" />
                <GradientStop Color="#EAF0F8" Offset="0.5" />
                <GradientStop Color="#DEE7F2" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="FModelJP5InputBackgroundDark" Color="#CC0F172A" />
            <SolidColorBrush x:Key="FModelJP5InputBackgroundLight" Color="#FFFDFEFF" />
            <SolidColorBrush x:Key="FModelJP5InputBorderDark" Color="#4D93C5FD" />
            <SolidColorBrush x:Key="FModelJP5InputBorderLight" Color="#334980B8" />

            <Style x:Key="FModelJP5Card" TargetType="Border">
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="Background" Value="#2B111827" />
                <Setter Property="BorderBrush" Value="#33000000" />
                <Setter Property="BorderThickness" Value="1" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UseDarkTheme, Source={x:Static settings:UserSettings.Default}}" Value="False">
                        <Setter Property="Background" Value="#EFFFFFFF" />
                        <Setter Property="BorderBrush" Value="#22111C2E" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="FModelJP5Input" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="adonisExtensions:CornerRadiusExtension.CornerRadius" Value="8" />
                <Setter Property="Background" Value="{StaticResource FModelJP5InputBackgroundDark}" />
                <Setter Property="BorderBrush" Value="{StaticResource FModelJP5InputBorderDark}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="8,5" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UseDarkTheme, Source={x:Static settings:UserSettings.Default}}" Value="False">
                        <Setter Property="Background" Value="{StaticResource FModelJP5InputBackgroundLight}" />
                        <Setter Property="BorderBrush" Value="{StaticResource FModelJP5InputBorderLight}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="FModelJP5PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Background" Value="{DynamicResource {x:Static adonisUi:Brushes.AccentBrush}}" />
                <Setter Property="BorderBrush" Value="#664A90E2" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="adonisExtensions:CornerRadiusExtension.CornerRadius" Value="12" />
            </Style>
            <Style x:Key="FModelJP5SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Background" Value="#99213357" />
                <Setter Property="BorderBrush" Value="#664A90E2" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="adonisExtensions:CornerRadiusExtension.CornerRadius" Value="12" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UseDarkTheme, Source={x:Static settings:UserSettings.Default}}" Value="False">
                        <Setter Property="Background" Value="#FFEAF2FF" />
                        <Setter Property="BorderBrush" Value="#335C8DC4" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Opacity" Value="0.85" />
                <Setter Property="Margin" Value="0,0,8,0" />
            </Style>
        </ResourceDictionary>
    </adonisControls:AdonisWindow.Resources>

    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Background" Value="{StaticResource FModelJP5WindowBackgroundDark}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UseDarkTheme, Source={x:Static settings:UserSettings.Default}}" Value="False">
                        <Setter Property="Background" Value="{StaticResource FModelJP5WindowBackgroundLight}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="410" />
        </Grid.ColumnDefinitions>

        <!-- ===== 左: プレビュー ===== -->
        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource FModelJP5Card}" Margin="10,10,5,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,2,8">
                    <TextBlock Text="プレビュー" Style="{StaticResource SectionHeader}" Margin="0" />
                    <TextBlock Text="{Binding ContextInfo}" Opacity="0.7" Margin="12,0,0,0" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Border Grid.Row="1" x:Name="PreviewArea" Background="#22000000" CornerRadius="10"
                        SizeChanged="OnPreviewAreaSizeChanged" PreviewMouseWheel="OnPreviewWheel" ClipToBounds="True">
                    <Canvas x:Name="PreviewCanvas" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="PreviewImg" Canvas.Left="0" Canvas.Top="0"
                               Source="{Binding PreviewImage}" Stretch="Fill"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Canvas>
                </Border>
            </Grid>
        </Border>

        <!-- ===== 右: 設定パネル ===== -->
        <ScrollViewer Grid.Row="0" Grid.Column="1" Margin="5,10,10,5" VerticalScrollBarVisibility="Auto"
                      adonisExtensions:ScrollViewerExtension.VerticalScrollBarPlacement="Docked">
            <StackPanel>
                <!-- 画像タイプ -->
                <Border Style="{StaticResource FModelJP5Card}">
                    <StackPanel>
                        <TextBlock Text="画像タイプ（プレビュー＝生成タイプ）" Style="{StaticResource SectionHeader}" />
                        <ComboBox ItemsSource="{Binding Styles}" SelectedItem="{Binding SelectedStyle, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={x:Static converters:EnumToStringConverter.Instance}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Border Margin="0,10,0,0" CornerRadius="10" Padding="12,10" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#33E0A030" />
                                    <Setter Property="BorderBrush" Value="#80E0A030" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOriginal}" Value="True">
                                            <Setter Property="Background" Value="#3357A773" />
                                            <Setter Property="BorderBrush" Value="#8057A773" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock TextWrapping="Wrap" Opacity="0.9">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="このタイプの組み込みプレビューです。下の項目を編集・反映するには「オリジナル」を選んでください。" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOriginal}" Value="True">
                                                <Setter Property="Text" Value="オリジナル — 下の項目とプレビューの枠ドラッグで自作レイアウトを編集でき、この内容で生成されます。" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- カテゴリ -->
                <Border Style="{StaticResource FModelJP5Card}">
                    <StackPanel>
                        <TextBlock Text="カテゴリ" Style="{StaticResource SectionHeader}" />
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={x:Static converters:IconLayoutLabelConverter.Instance}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Margin="0,8,0,0" Opacity="0.65" TextWrapping="Wrap"
                                   Text="プレビュー上の枠をドラッグで移動、要素を選択してマウスホイールでサイズ変更できます。名前欄にはそのアイテムの名前（武器なら武器名、スキンならスキン名）が入ります。" />
                    </StackPanel>
                </Border>

                <!-- キャンバス -->
                <Border Style="{StaticResource FModelJP5Card}">
                    <StackPanel>
                        <TextBlock Text="キャンバスサイズ" Style="{StaticResource SectionHeader}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="幅" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1" Style="{StaticResource FModelJP5Input}"
                                     Text="{Binding CurrentTemplate.Width, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <TextBlock Grid.Column="3" Text="高さ" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="4" Style="{StaticResource FModelJP5Input}"
                                     Text="{Binding CurrentTemplate.Height, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 背景 -->
                <Border Style="{StaticResource FModelJP5Card}">
                    <StackPanel>
                        <TextBlock Text="背景" Style="{StaticResource SectionHeader}" />
                        <ComboBox ItemsSource="{Binding BackgroundModes}" SelectedItem="{Binding CurrentTemplate.BackgroundMode, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={x:Static converters:IconLayoutLabelConverter.Instance}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel Margin="0,10,0,0"
                                    Visibility="{Binding CurrentTemplate.BackgroundMode, Converter={x:Static converters:EnumToVisibilityConverter.Instance}, ConverterParameter=SolidColor}">
                            <TextBlock Text="背景色" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                            <controls:ColorPickerMini Hex="{Binding CurrentTemplate.BackgroundColor, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Margin="0,10,0,0"
                                    Visibility="{Binding CurrentTemplate.BackgroundMode, Converter={x:Static converters:EnumToVisibilityConverter.Instance}, ConverterParameter=Image}">
                            <TextBlock Text="背景画像" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource FModelJP5Input}"
                                         Text="{Binding CurrentTemplate.BackgroundImagePath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                <Button Grid.Column="1" Margin="8,0,0,0" Content="参照..." Click="OnBrowseBackground"
                                        Style="{StaticResource FModelJP5SecondaryButton}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- プレビュー画像 -->
                <Border Style="{StaticResource FModelJP5Card}">
                    <StackPanel>
                        <CheckBox IsChecked="{Binding CurrentTemplate.Preview.Visible, Mode=TwoWay}"
                                  Content="プレビュー画像を表示" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1" Style="{StaticResource FModelJP5Input}"
                                     Text="{Binding CurrentTemplate.Preview.X, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N0}" />
                            <TextBlock Grid.Column="3" Text="Y" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="4" Style="{StaticResource FModelJP5Input}"
                                     Text="{Binding CurrentTemplate.Preview.Y, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N0}" />
                        </Grid>
                        <TextBlock Text="{Binding CurrentTemplate.Preview.Width, StringFormat='幅: {0:N0}'}" Opacity="0.85" />
                        <Slider Minimum="1" Maximum="2048" Value="{Binding CurrentTemplate.Preview.Width, Mode=TwoWay}" />
                        <TextBlock Text="{Binding CurrentTemplate.Preview.Height, StringFormat='高さ: {0:N0}'}" Opacity="0.85" Margin="0,4,0,0" />
                        <Slider Minimum="1" Maximum="2048" Value="{Binding CurrentTemplate.Preview.Height, Mode=TwoWay}" />
                        <CheckBox Margin="0,8,0,0" IsChecked="{Binding CurrentTemplate.Preview.KeepAspect, Mode=TwoWay}"
                                  Content="縦横比を維持" />
                    </StackPanel>
                </Border>

                <!-- 名前 -->
                <Border Style="{StaticResource FModelJP5Card}">
                    <StackPanel>
                        <CheckBox IsChecked="{Binding CurrentTemplate.Name.Visible, Mode=TwoWay}"
                                  Content="名前を表示" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1" Style="{StaticResource FModelJP5Input}"
                                     Text="{Binding CurrentTemplate.Name.X, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N0}" />
                            <TextBlock Grid.Column="3" Text="Y" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="4" Style="{StaticResource FModelJP5Input}"
                                     Text="{Binding CurrentTemplate.Name.Y, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N0}" />
                        </Grid>
                        <TextBlock Text="{Binding CurrentTemplate.Name.Width, StringFormat='幅(整列範囲): {0:N0}'}" Opacity="0.85" />
                        <Slider Minimum="1" Maximum="2048" Value="{Binding CurrentTemplate.Name.Width, Mode=TwoWay}" />
                        <TextBlock Text="{Binding CurrentTemplate.Name.FontSize, StringFormat='フォントサイズ: {0:N0}'}" Opacity="0.85" Margin="0,4,0,0" />
                        <Slider Minimum="6" Maximum="300" Value="{Binding CurrentTemplate.Name.FontSize, Mode=TwoWay}" />
                        <TextBlock Text="整列" Style="{StaticResource FieldLabel}" Margin="0,8,0,4" />
                        <ComboBox ItemsSource="{Binding Aligns}" SelectedItem="{Binding CurrentTemplate.Name.Align, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={x:Static converters:IconLayoutLabelConverter.Instance}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="文字色" Style="{StaticResource FieldLabel}" Margin="0,10,0,4" />
                        <controls:ColorPickerMini Hex="{Binding CurrentTemplate.Name.Color, Mode=TwoWay}" />
                        <TextBlock Text="縁取り色" Style="{StaticResource FieldLabel}" Margin="0,10,0,4" />
                        <controls:ColorPickerMini Hex="{Binding CurrentTemplate.Name.OutlineColor, Mode=TwoWay}" />
                        <TextBlock Text="{Binding CurrentTemplate.Name.OutlineThickness, StringFormat='縁取りの太さ: {0:N1}'}" Opacity="0.85" Margin="0,8,0,0" />
                        <Slider Minimum="0" Maximum="30" Value="{Binding CurrentTemplate.Name.OutlineThickness, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <!-- 説明 -->
                <Border Style="{StaticResource FModelJP5Card}">
                    <StackPanel>
                        <CheckBox IsChecked="{Binding CurrentTemplate.Description.Visible, Mode=TwoWay}"
                                  Content="説明を表示" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1" Style="{StaticResource FModelJP5Input}"
                                     Text="{Binding CurrentTemplate.Description.X, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N0}" />
                            <TextBlock Grid.Column="3" Text="Y" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="4" Style="{StaticResource FModelJP5Input}"
                                     Text="{Binding CurrentTemplate.Description.Y, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N0}" />
                        </Grid>
                        <TextBlock Text="{Binding CurrentTemplate.Description.Width, StringFormat='幅(折返し): {0:N0}'}" Opacity="0.85" />
                        <Slider Minimum="1" Maximum="2048" Value="{Binding CurrentTemplate.Description.Width, Mode=TwoWay}" />
                        <TextBlock Text="{Binding CurrentTemplate.Description.FontSize, StringFormat='フォントサイズ: {0:N0}'}" Opacity="0.85" Margin="0,4,0,0" />
                        <Slider Minimum="6" Maximum="200" Value="{Binding CurrentTemplate.Description.FontSize, Mode=TwoWay}" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="最大行数" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1" Style="{StaticResource FModelJP5Input}"
                                     Text="{Binding CurrentTemplate.Description.MaxLines, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </Grid>
                        <TextBlock Text="整列" Style="{StaticResource FieldLabel}" Margin="0,8,0,4" />
                        <ComboBox ItemsSource="{Binding Aligns}" SelectedItem="{Binding CurrentTemplate.Description.Align, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={x:Static converters:IconLayoutLabelConverter.Instance}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="文字色" Style="{StaticResource FieldLabel}" Margin="0,10,0,4" />
                        <controls:ColorPickerMini Hex="{Binding CurrentTemplate.Description.Color, Mode=TwoWay}" />
                        <TextBlock Text="縁取り色" Style="{StaticResource FieldLabel}" Margin="0,10,0,4" />
                        <controls:ColorPickerMini Hex="{Binding CurrentTemplate.Description.OutlineColor, Mode=TwoWay}" />
                        <TextBlock Text="{Binding CurrentTemplate.Description.OutlineThickness, StringFormat='縁取りの太さ: {0:N1}'}" Opacity="0.85" Margin="0,8,0,0" />
                        <Slider Minimum="0" Maximum="30" Value="{Binding CurrentTemplate.Description.OutlineThickness, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ===== 下: ボタン ===== -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                adonisExtensions:LayerExtension.IncreaseLayer="True">
            <Grid Margin="14,10">
                <TextBlock VerticalAlignment="Center" Opacity="0.65"
                           Text="ヒント: 枠をドラッグで移動、選択してホイールでサイズ変更。設定は書き出し/読み込みで共有できます。" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button MinWidth="96" Content="書き出し" Click="OnExport" Style="{StaticResource FModelJP5SecondaryButton}" />
                    <Button MinWidth="96" Margin="8,0,0,0" Content="読み込み" Click="OnImport" Style="{StaticResource FModelJP5SecondaryButton}" />
                    <Button MinWidth="110" Margin="8,0,0,0" Content="既定に戻す" Click="OnReset" Style="{StaticResource FModelJP5SecondaryButton}" />
                    <Button MinWidth="90" Margin="8,0,0,0" Content="保存" Click="OnSave" Style="{StaticResource FModelJP5PrimaryButton}" />
                    <Button MinWidth="90" Margin="8,0,0,0" Content="閉じる" Click="OnClose" Style="{StaticResource FModelJP5SecondaryButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</adonisControls:AdonisWindow>
