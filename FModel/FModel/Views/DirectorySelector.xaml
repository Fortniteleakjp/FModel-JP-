<adonisControls:AdonisWindow x:Class="FModel.Views.DirectorySelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FModel.Views.Resources.Controls"
        xmlns:converters="clr-namespace:FModel.Views.Resources.Converters"
        xmlns:settings="clr-namespace:FModel.Settings"
        xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
        xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
        xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" IconVisibility="Collapsed" SizeToContent="Height"
        MinHeight="{Binding Source={x:Static SystemParameters.MaximizedPrimaryScreenHeight}, Converter={converters:RatioConverter}, ConverterParameter='0.20'}"
        Width="{Binding Source={x:Static SystemParameters.MaximizedPrimaryScreenWidth}, Converter={converters:RatioConverter}, ConverterParameter='0.25'}">
    <adonisControls:AdonisWindow.Style>
        <Style TargetType="adonisControls:AdonisWindow" BasedOn="{StaticResource {x:Type adonisControls:AdonisWindow}}" >
            <Setter Property="Title" Value="Directory Selector" />
        </Style>
    </adonisControls:AdonisWindow.Style>
    <adonisControls:AdonisWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <LinearGradientBrush x:Key="FModelJP5WindowBackgroundDark" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#111827" Offset="0" />
                <GradientStop Color="#1F2937" Offset="0.5" />
                <GradientStop Color="#0B1220" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="FModelJP5WindowBackgroundLight" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F4F7FB" Offset="0" />
                <GradientStop Color="#EAF0F8" Offset="0.5" />
                <GradientStop Color="#DEE7F2" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="FModelJP5InputBackgroundDark" Color="#CC0F172A" />
            <SolidColorBrush x:Key="FModelJP5InputBackgroundLight" Color="#FFFDFEFF" />
            <SolidColorBrush x:Key="FModelJP5InputBorderDark" Color="#4D93C5FD" />
            <SolidColorBrush x:Key="FModelJP5InputBorderLight" Color="#334980B8" />

            <Style x:Key="FModelJP5Card" TargetType="Border">
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="Background" Value="#2B111827" />
                <Setter Property="BorderBrush" Value="#33000000" />
                <Setter Property="BorderThickness" Value="1" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UseDarkTheme, Source={x:Static settings:UserSettings.Default}}" Value="False">
                        <Setter Property="Background" Value="#EFFFFFFF" />
                        <Setter Property="BorderBrush" Value="#22111C2E" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="FModelJP5GroupBox" TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="#4D93C5FD" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="adonisExtensions:CornerRadiusExtension.CornerRadius" Value="12" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UseDarkTheme, Source={x:Static settings:UserSettings.Default}}" Value="False">
                        <Setter Property="BorderBrush" Value="#334980B8" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="FModelJP5Label" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Opacity" Value="0.92" />
            </Style>

            <Style x:Key="FModelJP5TextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="adonisExtensions:CornerRadiusExtension.CornerRadius" Value="10" />
                <Setter Property="Background" Value="{StaticResource FModelJP5InputBackgroundDark}" />
                <Setter Property="BorderBrush" Value="{StaticResource FModelJP5InputBorderDark}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10,6" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UseDarkTheme, Source={x:Static settings:UserSettings.Default}}" Value="False">
                        <Setter Property="Background" Value="{StaticResource FModelJP5InputBackgroundLight}" />
                        <Setter Property="BorderBrush" Value="{StaticResource FModelJP5InputBorderLight}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="FModelJP5ComboBox" TargetType="ComboBox" BasedOn="{StaticResource UComboBox}">
                <Setter Property="adonisExtensions:CornerRadiusExtension.CornerRadius" Value="10" />
                <Setter Property="Background" Value="{StaticResource FModelJP5InputBackgroundDark}" />
                <Setter Property="BorderBrush" Value="{StaticResource FModelJP5InputBorderDark}" />
                <Setter Property="BorderThickness" Value="1" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UseDarkTheme, Source={x:Static settings:UserSettings.Default}}" Value="False">
                        <Setter Property="Background" Value="{StaticResource FModelJP5InputBackgroundLight}" />
                        <Setter Property="BorderBrush" Value="{StaticResource FModelJP5InputBorderLight}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="FModelJP5PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Background" Value="{DynamicResource {x:Static adonisUi:Brushes.AccentBrush}}" />
                <Setter Property="BorderBrush" Value="#664A90E2" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="adonisExtensions:CornerRadiusExtension.CornerRadius" Value="12" />
            </Style>

            <Style x:Key="FModelJP5SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Background" Value="#99213357" />
                <Setter Property="BorderBrush" Value="#664A90E2" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="adonisExtensions:CornerRadiusExtension.CornerRadius" Value="12" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UseDarkTheme, Source={x:Static settings:UserSettings.Default}}" Value="False">
                        <Setter Property="Background" Value="#FFEAF2FF" />
                        <Setter Property="BorderBrush" Value="#335C8DC4" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="FModelJP5IconButton" TargetType="Button" BasedOn="{StaticResource FModelJP5SecondaryButton}">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="32" />
            </Style>
        </ResourceDictionary>
    </adonisControls:AdonisWindow.Resources>
    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Background" Value="{StaticResource FModelJP5WindowBackgroundDark}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UseDarkTheme, Source={x:Static settings:UserSettings.Default}}" Value="False">
                        <Setter Property="Background" Value="{StaticResource FModelJP5WindowBackgroundLight}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="10,8,10,0" Style="{StaticResource FModelJP5Card}">
            <StackPanel Orientation="Vertical">
            <TextBlock Text="説明" HorizontalAlignment="Center" FontSize="20" FontWeight="SemiBold" />
            <TextBlock TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center"
                Text="「利用可能」から選ぶか、任意のゲームを手動で追加してください。&#x0a;[LIVE] はクラウドから、それ以外はパソコンからデータを取得します。&#x0a;この手順を必ずお忘れなく！"/>
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="1" adonisExtensions:LayerExtension.Layer="2" Margin="10 10 10 18"
                  Style="{StaticResource FModelJP5GroupBox}"
                  Padding="{adonisUi:Space 0}" Background="Transparent">
            <StackPanel>
                <Grid x:Name="Hello" Margin="0 5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="利用可能" VerticalAlignment="Center" Margin="0 0 0 5" Style="{StaticResource FModelJP5Label}" />
                    <controls:FilterableComboBox Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3"
                                                 ItemsSource="{Binding DetectedDirectories}" Margin="0 0 0 5"
                                                 Style="{StaticResource FModelJP5ComboBox}"
                                                 adonisExtensions:WatermarkExtension.Watermark="Search for a game..."
                                                 VerticalAlignment="Center" SelectedItem="{Binding SelectedDirectory, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding GameName, Converter={x:Static converters:StringToGameConverter.Instance}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </controls:FilterableComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="UE バージョン" VerticalAlignment="Center" Margin="0 0 0 5" Style="{StaticResource FModelJP5Label}" />
                    <controls:FilterableComboBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3" Margin="0 0 0 5"
                                                 ItemsSource="{Binding UeGames}"
                                                 Style="{StaticResource FModelJP5ComboBox}"
                                                 VerticalAlignment="Center" SelectedItem="{Binding SelectedDirectory.UeVersion, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={x:Static converters:EnumToStringConverter.Instance}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </controls:FilterableComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="ゲームフォルダ" VerticalAlignment="Center" Style="{StaticResource FModelJP5Label}" />
                        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding SelectedDirectory.GameDirectory, Mode=TwoWay}" Style="{StaticResource FModelJP5TextBox}" />
                        <Button Grid.Row="2" Grid.Column="4" Content="..." HorizontalAlignment="Right" Tag="Main" Click="OnBrowseDirectories" Style="{StaticResource FModelJP5SecondaryButton}" />
                        <Button Grid.Row="2" Grid.Column="4" Style="{StaticResource FModelJP5IconButton}"
                            Click="OnDeleteDirectory" Width="{Binding ActualWidth, ElementName=OkGuysButWhoFuckingAsked}" ToolTip="Delete Game"
                            Visibility="{Binding SelectedDirectory.IsManual, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Viewbox Width="16" Height="16" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Data="{StaticResource RemoveIcon}" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>

                <Expander Grid.Row="7"
                          Grid.Column="0"
                          Grid.ColumnSpan="7"
                          Margin="0,4,0,0"
                          Style="{StaticResource ExpanderButtonLikeHeader}"
                          Header="Show Compare Game Selection"
                          Visibility="{Binding AllowDiffSelection, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Expander.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" />
                        </Style>
                    </Expander.Resources>
                    <Grid Margin="8,4,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Compared Game"
                                   VerticalAlignment="Center"
                                   Margin="0 0 0 5" Style="{StaticResource FModelJP5Label}" />
                        <controls:FilterableComboBox Grid.Row="0"
                                                     Grid.Column="2"
                                                     Grid.ColumnSpan="3"
                                                     Margin="0 0 0 5"
                                                     ItemsSource="{Binding DetectedDirectories}"
                                                     Style="{StaticResource FModelJP5ComboBox}"
                                                     adonisExtensions:WatermarkExtension.Watermark="Search for a game build to compare.."
                                                     VerticalAlignment="Center"
                                                     SelectedItem="{Binding SelectedDiffDirectory, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding GameName, Converter={x:Static converters:StringToGameConverter.Instance}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </controls:FilterableComboBox>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="UEバージョン"
                                   VerticalAlignment="Center"
                                   Margin="0 0 0 5" Style="{StaticResource FModelJP5Label}" />
                        <controls:FilterableComboBox Grid.Row="1"
                                                     Grid.Column="2"
                                                     Grid.ColumnSpan="3"
                                                     Margin="0 0 0 5"
                                                     ItemsSource="{Binding DiffUeGames}"
                                                     Style="{StaticResource FModelJP5ComboBox}"
                                                     VerticalAlignment="Center"
                                                     SelectedItem="{Binding SelectedDiffDirectory.UeVersion, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={x:Static converters:EnumToStringConverter.Instance}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </controls:FilterableComboBox>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="Directory"
                               VerticalAlignment="Center" Style="{StaticResource FModelJP5Label}" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="2"
                             Text="{Binding SelectedDiffDirectory.GameDirectory, Mode=TwoWay}" Style="{StaticResource FModelJP5TextBox}" />
                        <Button Grid.Row="2"
                                Grid.Column="4"
                                Content="..."
                                HorizontalAlignment="Right"
                                Click="OnBrowseDirectories"
                            Tag="Diff" Style="{StaticResource FModelJP5SecondaryButton}" />
                    </Grid>
                </Expander>

                <Separator Style="{StaticResource CustomSeparator}" Tag="未検出のゲームを指定" />

                <Expander ExpandDirection="Down" IsExpanded="False">
                    <Grid MaxWidth="{Binding ActualWidth, ElementName=Hello}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="5" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ゲーム名" VerticalAlignment="Center" Style="{StaticResource FModelJP5Label}" />
                        <TextBox x:Name="HelloMyNameIsGame" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="5" Style="{StaticResource FModelJP5TextBox}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="ゲームのフォルダ" VerticalAlignment="Center" Style="{StaticResource FModelJP5Label}" />
                        <TextBox x:Name="HelloGameMyNameIsDirectory" Grid.Row="2" Grid.Column="2" Style="{StaticResource FModelJP5TextBox}" />
                        <Button x:Name="OkGuysButWhoFuckingAsked" Grid.Row="2" Grid.Column="4" Content="..." HorizontalAlignment="Right" Click="OnBrowseManualDirectories" Style="{StaticResource FModelJP5SecondaryButton}" />
                        <Button Grid.Row="2" Grid.Column="6" Style="{StaticResource FModelJP5IconButton}"
                                Click="OnAddDirectory" ToolTip="Add Game" Width="{Binding ActualWidth, ElementName=OkGuysButWhoFuckingAsked}">
                            <Viewbox Width="16" Height="16" HorizontalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Data="{StaticResource AddIcon}" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Expander>
            </StackPanel>
        </GroupBox>

        <Border Grid.Row="2"
                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
            adonisExtensions:LayerExtension.IncreaseLayer="True"
            CornerRadius="0,0,12,12">
            <Grid Margin="30, 12, 6, 12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" MinWidth="78" Margin="0 0 12 0" IsDefault="True" IsCancel="False"
                    Style="{StaticResource FModelJP5PrimaryButton}"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Content="決定" Click="OnClick" />
                <Button Grid.Column="2" MinWidth="78" Margin="0 0 12 0" IsDefault="False"  IsCancel="True"
                    Style="{StaticResource FModelJP5SecondaryButton}"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Content="キャンセル" />
            </Grid>
        </Border>
    </Grid>
</adonisControls:AdonisWindow>