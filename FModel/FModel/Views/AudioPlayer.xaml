<adonisControls:AdonisWindow x:Class="FModel.Views.AudioPlayer"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:local="clr-namespace:FModel"
         xmlns:audioControls="clr-namespace:FModel.Views.Resources.Controls.Aup"
         xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
         xmlns:converters="clr-namespace:FModel.Views.Resources.Converters"
         xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
         xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
         xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
         WindowStartupLocation="CenterScreen" IconVisibility="Collapsed"
         Closing="OnClosing" PreviewKeyDown="OnPreviewKeyDown" Activated="OnActivatedDeactivated" Deactivated="OnActivatedDeactivated"
         Height="{Binding Source={x:Static SystemParameters.MaximizedPrimaryScreenHeight}, Converter={converters:RatioConverter}, ConverterParameter='0.50'}"
         Width="{Binding Source={x:Static SystemParameters.MaximizedPrimaryScreenWidth}, Converter={converters:RatioConverter}, ConverterParameter='0.55'}">
    <adonisControls:AdonisWindow.Style>
        <Style TargetType="adonisControls:AdonisWindow" BasedOn="{StaticResource {x:Type adonisControls:AdonisWindow}}" >
            <Setter Property="Title" Value="Audio Player" />
        </Style>
    </adonisControls:AdonisWindow.Style>
    <adonisControls:AdonisWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <LinearGradientBrush x:Key="AudioPlayerJP5Background" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#FF0F172A"/>
                <GradientStop Offset="0.45" Color="#FF1E293B"/>
                <GradientStop Offset="1" Color="#FF0B1120"/>
            </LinearGradientBrush>

            <Style x:Key="AudioPlayerJP5Card" TargetType="Border">
                <Setter Property="CornerRadius" Value="14"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#334A90E2"/>
                <Setter Property="Background" Value="#2B111827"/>
            </Style>

            <Style x:Key="AudioPlayerJP5ToolbarButton" TargetType="Button" BasedOn="{StaticResource {x:Static adonisUi:Styles.ToolbarButton}}">
                <Setter Property="Background" Value="#99213357"/>
                <Setter Property="BorderBrush" Value="#664A90E2"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="Margin" Value="10,0"/>
            </Style>

            <Style x:Key="AudioPlayerJP5PlayPauseButton" TargetType="Button" BasedOn="{StaticResource AudioPlayerJP5ToolbarButton}">
                <Setter Property="Width" Value="52"/>
                <Setter Property="Height" Value="52"/>
                <Setter Property="Background" Value="#FF2A9D8F"/>
                <Setter Property="BorderBrush" Value="#FF2A9D8F"/>
            </Style>

            <Style x:Key="AudioPlayerJP5ToggleButton" TargetType="primitives:ToggleButton">
                <Setter Property="Height" Value="30"/>
                <Setter Property="MinWidth" Value="88"/>
                <Setter Property="Foreground" Value="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                <Setter Property="Background" Value="#20FFFFFF"/>
                <Setter Property="BorderBrush" Value="#3FFFFFFF"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="primitives:ToggleButton">
                            <Border x:Name="Root" CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#35FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#FF2A9D8F"/>
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#FF2A9D8F"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="AudioPlayerJP5SettingLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Opacity" Value="0.92"/>
                <Setter Property="Foreground" Value="#FFD8E9FF"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>

            <Style x:Key="AudioPlayerJP5ComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="Background" Value="#CC0F172A"/>
                <Setter Property="BorderBrush" Value="#4D93C5FD"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="MinHeight" Value="34"/>
            </Style>

            <LinearGradientBrush x:Key="AudioPlayerJP5SettingsBackground" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#24111B2B"/>
                <GradientStop Offset="1" Color="#2A1E3A5F"/>
            </LinearGradientBrush>
        </ResourceDictionary>
    </adonisControls:AdonisWindow.Resources>
    <Grid Background="{StaticResource AudioPlayerJP5Background}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Library & Settings -->
        <Border Grid.Column="0" Margin="14" Style="{StaticResource AudioPlayerJP5Card}">
            <Grid Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Search -->
            <Grid Grid.Row="0" Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Viewbox Width="14" Height="14" Margin="0,0,8,0" Opacity="0.6">
                    <Canvas Width="24" Height="24">
                        <Path Fill="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Data="{StaticResource SearchIcon}" />
                    </Canvas>
                </Viewbox>
                <TextBox Grid.Column="1" AcceptsTab="False" AcceptsReturn="False"
                         TextChanged="OnFilterTextChanged"
                         BorderThickness="0,0,0,1" Background="Transparent" Padding="2"
                         adonisExtensions:WatermarkExtension.Watermark="{DynamicResource AudioPlayer_SearchPlaceholder}" />
            </Grid>

            <!-- Playlist -->
            <ListBox x:Name="AudioListBox" Grid.Row="1" Style="{StaticResource AudioFilesListBox}" PreviewMouseDoubleClick="OnAudioFileMouseDoubleClick"
                     SelectionMode="Extended"
                     BorderThickness="0" Background="Transparent" Margin="0,0,0,10">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{DynamicResource AudioPlayer_Ctx_Play}" Command="{Binding AudioPlayer.AudioCommand}" CommandParameter="ForcePlayPause">
                            <MenuItem.Icon>
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Data="{StaticResource PlayIcon}" />
                                    </Canvas>
                                </Viewbox>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource AudioPlayer_Ctx_Remove}" Command="{Binding AudioPlayer.AudioCommand}" CommandParameter="Remove">
                            <MenuItem.Icon>
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Data="{StaticResource RemoveIcon}" />
                                    </Canvas>
                                </Viewbox>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource AudioPlayer_Ctx_Save}" Click="OnSaveAudioFiles">
                            <MenuItem.Icon>
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Data="{StaticResource SaveIcon}" />
                                    </Canvas>
                                </Viewbox>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource AudioPlayer_Ctx_SavePlaylist}" Command="{Binding AudioPlayer.AudioCommand}" CommandParameter="Save_Playlist">
                            <MenuItem.Icon>
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Data="{StaticResource SavePlaylistIcon}" />
                                    </Canvas>
                                </Viewbox>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </ListBox.ContextMenu>
            </ListBox>

            <!-- Settings (Bottom) -->
            <Border Grid.Row="2" BorderThickness="0,1,0,0" 
                    BorderBrush="#4DFFFFFF" 
                    Padding="15" Background="{StaticResource AudioPlayerJP5SettingsBackground}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource AudioPlayer_PlaybackDevice}" Style="{StaticResource AudioPlayerJP5SettingLabel}"/>
                    <ComboBox Style="{StaticResource AudioPlayerJP5ComboBox}"
                              ItemsSource="{Binding AudioPlayer.AudioDevicesView, IsAsync=True}"
                              SelectedItem="{Binding AudioPlayer.SelectedAudioDevice, Mode=TwoWay}" 
                              SelectionChanged="OnDeviceSwap" Margin="0,0,0,12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FriendlyName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource AudioPlayer_Volume}" Style="{StaticResource AudioPlayerJP5SettingLabel}" VerticalAlignment="Center" Margin="0"/>
                        <Slider Grid.Column="1" Margin="10,0" Minimum="0" Maximum="100" 
                                ValueChanged="OnVolumeChange"
                                Value="{Binding AudioPlayerVolume, Source={x:Static local:Settings.UserSettings.Default}, Mode=TwoWay}" 
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AudioPlayerVolume, Source={x:Static local:Settings.UserSettings.Default}, StringFormat={}{0}%}" 
                                   FontSize="11" Opacity="0.7" VerticalAlignment="Center" Grid.Column="2"/>
                    </Grid>
                </StackPanel>
            </Border>
            </Grid>
        </Border>

        <!-- Right Panel: Visualizer & Controls -->
        <Grid Grid.Column="1" ClipToBounds="True">
            <!-- Background Visualizer -->
            <audioControls:SpectrumAnalyzer Opacity="0.8" Margin="0,0,0,150"/>

            <!-- Top Info Overlay -->
            <Grid VerticalAlignment="Top" Margin="25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="1" CornerRadius="10" Padding="10,4" Margin="10,0,0,0"
                        Background="#99213357" BorderBrush="#664A90E2" BorderThickness="1"
                        VerticalAlignment="Top">
                    <TextBlock Text="JP5.0 AUDIO" FontSize="11" FontWeight="Bold" Foreground="White"/>
                </Border>

                <!-- File Stats -->
                <StackPanel Grid.Column="0" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Background="{DynamicResource {x:Static adonisUi:Brushes.Layer3BackgroundBrush}}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                            <TextBlock Text="{Binding AudioPlayer.PlayedFile.Encoding, Converter={x:Static converters:EnumToStringConverter.Instance}}" FontWeight="Bold" FontSize="10"/>
                        </Border>
                        <Border Background="{DynamicResource {x:Static adonisUi:Brushes.Layer3BackgroundBrush}}" CornerRadius="4" Padding="6,2">
                            <TextBlock Text="{Binding AudioPlayer.PlayedFile.BytesPerSecond}" FontSize="10"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <audioControls:Timeclock VerticalAlignment="Bottom">
                            <audioControls:Timeclock.LayoutTransform>
                                <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                            </audioControls:Timeclock.LayoutTransform>
                        </audioControls:Timeclock>
                        <TextBlock Text=" / " FontSize="28" FontWeight="Light" Opacity="0.5" VerticalAlignment="Bottom" Margin="10,0,10,2"/>
                        <TextBlock Text="{Binding AudioPlayer.PlayedFile.Duration}" FontSize="28" FontWeight="Light" Opacity="0.5" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Bottom Floating Controls -->
                <Border VerticalAlignment="Bottom" Margin="20" CornerRadius="12"
                    Background="#B20F172A"
                    BorderBrush="#664A90E2" BorderThickness="1"
                    Padding="20,15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.2" Direction="270"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Timeline -->
                    <audioControls:Timeline Grid.Row="0" Margin="0,0,0,10"/>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource AudioPlayerJP5ToolbarButton}" ToolTip="Previous"
                                Command="{Binding AudioPlayer.AudioCommand}" CommandParameter="Previous">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Data="{StaticResource SkipPreviousIcon}" />
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <Button Style="{StaticResource AudioPlayerJP5PlayPauseButton}"
                                Command="{Binding AudioPlayer.AudioCommand}" CommandParameter="PlayPause" 
                                Margin="15,0"/>

                        <Button Style="{StaticResource AudioPlayerJP5ToolbarButton}" ToolTip="Next"
                                Command="{Binding AudioPlayer.AudioCommand}" CommandParameter="Next">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Data="{StaticResource SkipNextIcon}" />
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <primitives:ToggleButton Style="{StaticResource AudioPlayerJP5ToggleButton}"
                                                 Margin="14,0,0,0"
                                                 ToolTip="Repeat current track"
                                                 IsChecked="{Binding AudioPlayer.IsRepeatOne, Mode=TwoWay}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Repeat" FontWeight="SemiBold"/>
                                <TextBlock Text=" 1" FontWeight="Bold"/>
                            </StackPanel>
                        </primitives:ToggleButton>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</adonisControls:AdonisWindow>
