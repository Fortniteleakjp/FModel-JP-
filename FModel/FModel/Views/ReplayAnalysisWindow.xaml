<adonisControls:AdonisWindow x:Class="FModel.Views.ReplayAnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
        xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
        mc:Ignorable="d"
        Title="リプレイ解析"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ReplayFilePathTextBox" Grid.Column="0" Margin="0,0,10,0" IsReadOnly="True" VerticalContentAlignment="Center" adonisExtensions:WatermarkExtension.Watermark="リプレイファイル (.replay) を選択してください..."/>
            <Button x:Name="SelectReplayFileButton" Grid.Column="1" Content="..." Padding="10,5" Click="OnSelectReplayFileClick" ToolTip="ファイルを選択"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="解析モード">
                <StackPanel Orientation="Horizontal" Margin="5">
                    <RadioButton x:Name="EventsOnlyRadioButton" Content="EventsOnly" GroupName="AnalysisMode" IsChecked="True" Margin="5"/>
                    <RadioButton x:Name="MinimalRadioButton" Content="Minimal" GroupName="AnalysisMode" Margin="5"/>
                    <RadioButton x:Name="NormalRadioButton" Content="Normal" GroupName="AnalysisMode" Margin="5"/>
                    <RadioButton x:Name="FullRadioButton" Content="Full" GroupName="AnalysisMode" Margin="5"/>
                </StackPanel>
            </GroupBox>

            <Button Grid.Column="1" x:Name="StartAnalysisButton" Content="解析開始" Padding="20,5" Click="OnStartAnalysisClick" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <Button Grid.Column="2" x:Name="SaveJsonButton" Content="JSONを保存" Padding="20,5" Click="OnSaveJsonClick" VerticalAlignment="Center" Margin="10,0,0,0" IsEnabled="False"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <TextBox x:Name="FilterTextBox" TextChanged="OnFilterTextChanged" adonisExtensions:WatermarkExtension.Watermark="プレイヤー名で検索..."/>
        </Grid>

        <TabControl Grid.Row="3">
            <TabItem Header="撃破リスト">
                <DataGrid x:Name="AnalysisResultDataGrid" IsReadOnly="True" AutoGenerateColumns="False" MouseDoubleClick="OnDataGridMouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="時間" Binding="{Binding Time, StringFormat='hh\\:mm\\:ss'}"/>
                        <DataGridTextColumn Header="キルしたプレイヤー" Binding="{Binding Eliminator}" Width="*"/>
                        <DataGridTextColumn Header="キルされたプレイヤー" Binding="{Binding Eliminated}" Width="*"/>
                        <DataGridTextColumn Header="武器" Binding="{Binding GunType}"/>
                        <DataGridCheckBoxColumn Header="ダウン" Binding="{Binding Knocked, Mode=OneWay}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="統計情報">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="最多キルプレイヤー" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
                        <TextBlock x:Name="MostKillsTextBlock" Text="-" Margin="0,0,0,15" FontSize="14"/>

                        <TextBlock Text="武器使用ランキング" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
                        <DataGrid x:Name="WeaponRankingDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="300" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="武器" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="キル数" Binding="{Binding Value}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="ヘッダー情報">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Branch" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="BranchTextBox" IsReadOnly="True" Margin="0,0,0,15"/>

                        <TextBlock Text="Level Names and Times" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ListBox x:Name="LevelNamesListBox" Height="200"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <ProgressBar Grid.Row="4" x:Name="AnalysisProgressBar" Height="10" Margin="0,10,0,0" IsIndeterminate="True" Visibility="Collapsed"/>
    </Grid>
</adonisControls:AdonisWindow>