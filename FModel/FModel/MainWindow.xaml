                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Visibility, ElementName=ThumbnailImage}" Value="Visible">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Viewbox.Style>
                                                            <Canvas Width="24" Height="24">
                                                                <Path Fill="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Data="{StaticResource NoteIcon}" />
                                                            </Canvas>
                                                        </Viewbox>

                                                        <Border Grid.Row="1" Background="{Binding Text, ElementName=AssetClassBadgeText, Converter={x:Static converters:AssetClassBadgeBrushConverter.Instance}, ConverterParameter=CardSectionBackground}"
                                                            CornerRadius="0,0,12,12" Padding="12,10">
                                                            <StackPanel>
                                                                 <TextBlock controls:WeaponCardNameLoader.GameFile="{Binding}"
                                                                     controls:HighlightText.Text="{Binding RelativeSource={RelativeSource Self}, Path=(controls:WeaponCardNameLoader.DisplayName)}"
                                                                       controls:HighlightText.Highlight="{Binding Text, ElementName=NewExplorerSearchBox}"
                                                                       controls:HighlightText.HighlightBrush="{DynamicResource {x:Static adonisUi:Brushes.AccentBrush}}"
                                                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis" HorizontalAlignment="Left"
                                                                     ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=(controls:WeaponCardNameLoader.DisplayName)}" Margin="0,0,0,4" FontSize="12"/>
                                                                <Border Background="{Binding Text, ElementName=AssetClassBadgeText, Converter={x:Static converters:AssetClassBadgeBrushConverter.Instance}, ConverterParameter=Background}"
                                                                    BorderBrush="{Binding Text, ElementName=AssetClassBadgeText, Converter={x:Static converters:AssetClassBadgeBrushConverter.Instance}, ConverterParameter=Border}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10"
                                                                    HorizontalAlignment="Center"
                                                                    Margin="0,0,0,4"
                                                                    Padding="7,2">
                                                                    <TextBlock x:Name="AssetClassBadgeText"
                                                                           controls:GameFileClassLoader.GameFile="{Binding}"
                                                                           Text="{Binding RelativeSource={RelativeSource Self}, Path=(controls:GameFileClassLoader.ClassName)}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Opacity="0.95"
                                                                           TextAlignment="Center"
                                                                           HorizontalAlignment="Center"
                                                                           Foreground="{Binding Text, RelativeSource={RelativeSource Self}, Converter={x:Static converters:AssetClassBadgeBrushConverter.Instance}, ConverterParameter=Foreground}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
                                                                </Border>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Size, Converter={x:Static converters:SizeToStringConverter.Instance}}" FontSize="10" Opacity="0.6" />
                                                                    <TextBlock Grid.Column="1" Text="{Binding Extension}" FontSize="10" Opacity="0.6" HorizontalAlignment="Right" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Border Grid.Row="2" Margin="0 5 0 5"
                                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer3BorderBrush}}"
                                BorderThickness="1" CornerRadius="12">
                            <DockPanel>
                                <ToggleButton x:Name="LogExpanderToggle" DockPanel.Dock="Top"
                                              IsChecked="{Binding IsLoggerExpanded, Source={x:Static settings:UserSettings.Default}, Mode=TwoWay}"
                                              Style="{StaticResource FModelJP5ExpanderHeader}">
                                    <DockPanel Margin="4,2">
                                        <TextBlock Text="ログ" FontWeight="SemiBold" VerticalAlignment="Center" Opacity="0.8"/>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource FModelJP5SearchActionButton}" ToolTip="出力フォルダを開く" Padding="6,4" Margin="4,0"
                                                    Command="{Binding MenuCommand}" CommandParameter="ToolBox_Open_Output_Directory">
                                                <Viewbox Width="14" Height="14" HorizontalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Data="{StaticResource FolderIcon}" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Button>
                                            <Button Style="{StaticResource FModelJP5SearchActionButton}" ToolTip="ログをクリア" Padding="6,4"
                                                    Command="{Binding MenuCommand}" CommandParameter="ToolBox_Clear_Logs">
                                                <Viewbox Width="14" Height="14" HorizontalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" Data="{StaticResource TrashIcon}"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                                </ToggleButton>
                                <Border x:Name="LogContainer" ClipToBounds="True">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Height" Value="0"/>
                                            <Setter Property="Opacity" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, ElementName=LogExpanderToggle}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Height" To="180" Duration="0:0:0.25" DecelerationRatio="0.5"/>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                                                                <ThicknessAnimation Storyboard.TargetProperty="Margin" To="4,0,4,4" Duration="0:0:0.25" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Height" To="0" Duration="0:0:0.2" AccelerationRatio="0.5"/>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                                                <ThicknessAnimation Storyboard.TargetProperty="Margin" To="0" Duration="0:0:0.2" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <controls:CustomRichTextBox x:Name="LogRtbName" Style="{StaticResource FModelJP5RichTextBox}" />
                                </Border>
                            </DockPanel>
                        </Border>
                    </Grid>
                </GroupBox>
            </Border>
        </Grid>

    </Grid>
</adonisControls:AdonisWindow>
